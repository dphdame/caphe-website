# CAPHE Website Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE (Authentication & Database)
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# OAUTH PROVIDERS
# ===========================================

# Google OAuth (console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# LinkedIn OAuth (linkedin.com/developers/apps)
LINKEDIN_CLIENT_ID=your-client-id
LINKEDIN_CLIENT_SECRET=your-client-secret

# ===========================================
# BREVO (Email Marketing)
# ===========================================
BREVO_API_KEY=xkeysib-your-api-key
BREVO_LIST_ID=9
BREVO_MEMBERS_LIST_ID=13
BREVO_EVENTS_LIST_ID=14
BREVO_APPLICATIONS_LIST_ID=15

# ===========================================
# ADMIN (comma-separated for multiple admins)
# ===========================================
ADMIN_EMAIL=admin1@example.com,admin2@example.com
